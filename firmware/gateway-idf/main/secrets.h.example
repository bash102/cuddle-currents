// Copy this file to `secrets.h` (same directory). secrets.h is gitignored.
//
// These are compile-time DEFAULTS. The MQTT broker/port and gateway id seed NVS on
// first boot and are overridable from the captive portal ("Cuddle-Gateway-Setup" ->
// http://192.168.4.1).
#pragma once

#define MQTT_BROKER "192.168.1.212"   // host running mosquitto (the Mac's LAN IP)
#define MQTT_PORT   1883

// Gateway id = this prefix + a per-chip MAC suffix (e.g. "esp32-01-a172e0"), so ONE
// firmware image flashed to a whole fleet is automatically unique on the broker. A name
// set explicitly via the portal (persisted in NVS) overrides this and is used verbatim.
#define GATEWAY_ID  "esp32-01"

// OPTIONAL — compile-time Wi-Fi credentials. If set (non-empty), a freshly-flashed gateway
// joins this network directly on boot, no captive portal needed — the fleet-friendly path.
// Leave empty (or delete both) to fall back to runtime portal provisioning. secrets.h is
// gitignored, so real credentials never enter the repo.
#define WIFI_SSID   ""
#define WIFI_PASS   ""
