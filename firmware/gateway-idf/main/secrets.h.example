// Copy this file to `secrets.h` (same directory). secrets.h is gitignored.
//
// NOTE: Wi-Fi is provisioned at RUNTIME via the captive portal (SoftAP
// "Cuddle-Gateway-Setup" -> http://192.168.4.1), NOT here — so no Wi-Fi password
// lives in the repo. These are only the compile-time DEFAULTS for the MQTT broker
// and gateway id: they seed NVS on first boot and are overridable from the portal.
#pragma once

#define MQTT_BROKER "192.168.1.212"   // host running mosquitto (the Mac's LAN IP)
#define MQTT_PORT   1883
#define GATEWAY_ID  "esp32-01"        // unique per gateway; appears in the MQTT topics
