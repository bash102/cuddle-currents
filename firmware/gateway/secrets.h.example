// Copy this file to `secrets.h` (same directory) and fill in your values.
// secrets.h is gitignored — never commit real Wi-Fi credentials.
#pragma once

#define WIFI_SSID   "your-wifi-ssid"
#define WIFI_PASS   "your-wifi-password"

#define MQTT_BROKER "192.168.1.212"   // host running mosquitto (the Mac's LAN IP)
#define MQTT_PORT   1883

#define GATEWAY_ID  "esp32-01"        // unique per gateway; appears in the MQTT topics
